datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  SINGLE
  MULTI
  MATCHING
  ORDERING
}

enum TestStatus {
  DRAFT
  OPEN
  CLOSED
}

enum SamplingMode {
  FROM_BANK
  BY_CATEGORY
}

enum ScoringMode {
  SUM
  PERCENTAGE
}

enum ShowResultMode {
  AFTER_FINISH
  ADMIN_ONLY
}

enum MultiScoringMode {
  ALL_OR_NOTHING
  PARTIAL
}

enum FinishReason {
  NORMAL
  TIMEOUT
  EXIT
}

enum SuspiciousEventType {
  FULLSCREEN_EXIT
  TAB_SWITCH
  WINDOW_BLUR
  WINDOW_RESIZE
  SCREENSHOT_ATTEMPT
}

enum FormFieldType {
  TEXT
  BOOLEAN
  INTEGER
  FLOAT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())

  groups        UserGroup[]
  createdTests  Test[]
  createdCategories QuestionCategory[] @relation("CreatedCategories")
  createdQuestions  Question[]         @relation("CreatedQuestions")
  createdForms      Form[]             @relation("CreatedForms")
  attempts      Attempt[]
  formSubmissions FormSubmission[]
  refreshTokens RefreshToken[]

  @@index([role])
}

model Group {
  id   String  @id @default(uuid())
  name String

  users      UserGroup[]
  testGroups TestGroup[]

  @@index([name])
}

model UserGroup {
  userId  String
  groupId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
}

model QuestionCategory {
  id           String  @id @default(uuid())
  name         String
  pointsWeight Float   @default(1.0)
  createdById  String?

  createdBy          User?             @relation("CreatedCategories", fields: [createdById], references: [id])
  questions          Question[]
  testCategoryQuotas TestCategoryQuota[]

  @@index([createdById])
}

model Question {
  id          String       @id @default(uuid())
  text        String       @db.Text
  type        QuestionType
  categoryId  String
  createdById String?
  imageUrl    String?
  createdAt   DateTime     @default(now())

  // New optional fields for matching and ordering types
  matchingPairs Json?   // [{ left: String, right: String }]
  orderingItems Json?   // [String]
  timeLimitSeconds Int?

  category         QuestionCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy        User?             @relation("CreatedQuestions", fields: [createdById], references: [id])
  answers          Answer[]
  testQuestions    TestQuestion[]
  attemptQuestions AttemptQuestion[]

  @@index([categoryId])
  @@index([createdById])
  @@index([type])
  @@index([createdAt])
}

model Answer {
  id         String  @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)

  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attemptAnswers AttemptAnswer[]

  @@index([questionId])
}

model Test {
  id               String           @id @default(uuid())
  title            String
  subject          String?
  createdById      String
  timeLimitMin     Int              @default(0)
  maxAttempts      Int              @default(1)
  openFrom         DateTime?
  openUntil        DateTime?
  status           TestStatus       @default(DRAFT)
  questionsCount   Int              @default(10)
  samplingMode     SamplingMode     @default(FROM_BANK)
  scoringMode      ScoringMode      @default(SUM)
  passThreshold    Float?
  showResultMode   ShowResultMode   @default(AFTER_FINISH)
  multiScoringMode MultiScoringMode @default(ALL_OR_NOTHING)
  createdAt        DateTime         @default(now())
  allowCertificate Boolean          @default(true)
  logoUrl          String?

  createdBy      User                @relation(fields: [createdById], references: [id])
  groups         TestGroup[]
  questions      TestQuestion[]
  categoryQuotas TestCategoryQuota[]
  attempts       Attempt[]

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model TestGroup {
  testId  String
  groupId String

  test  Test  @relation(fields: [testId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([testId, groupId])
  @@index([groupId])
}

model TestQuestion {
  testId     String
  questionId String

  test     Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([testId, questionId])
  @@index([questionId])
}

model TestCategoryQuota {
  testId     String
  categoryId String
  quota      Int

  test     Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  category QuestionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([testId, categoryId])
  @@index([categoryId])
}

model Attempt {
  id                    String        @id @default(uuid())
  studentId             String
  testId                String
  startedAt             DateTime      @default(now())
  finishedAt            DateTime?
  finishReason          FinishReason?
  score                 Float?
  maxScore              Float?
  suspiciousEventsCount Int           @default(0)
  currentQuestionIndex  Int           @default(0)

  student          User              @relation(fields: [studentId], references: [id])
  test             Test              @relation(fields: [testId], references: [id], onDelete: Cascade)
  attemptQuestions AttemptQuestion[]
  suspiciousEvents SuspiciousEvent[]

  @@index([studentId, testId])
  @@index([testId])
  @@index([startedAt])
}

model AttemptQuestion {
  id              String    @id @default(uuid())
  attemptId       String
  questionId      String
  orderIndex      Int
  answerOrder     Json
  answeredAt      DateTime?
  submittedAnswer Json?

  attempt        Attempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question        @relation(fields: [questionId], references: [id])
  attemptAnswers AttemptAnswer[]

  @@index([attemptId, orderIndex])
  @@index([questionId])
}

model AttemptAnswer {
  attemptQuestionId String
  answerId          String
  selected          Boolean @default(false)

  attemptQuestion AttemptQuestion @relation(fields: [attemptQuestionId], references: [id], onDelete: Cascade)
  answer          Answer          @relation(fields: [answerId], references: [id])

  @@id([attemptQuestionId, answerId])
  @@index([answerId])
}

model SuspiciousEvent {
  id         String              @id @default(uuid())
  attemptId  String
  eventType  SuspiciousEventType
  occurredAt DateTime            @default(now())

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Form {
  id           String   @id @default(uuid())
  title        String
  description  String?  @db.Text
  createdById  String
  createdAt    DateTime @default(now())
  status       TestStatus @default(DRAFT)

  createdBy    User          @relation("CreatedForms", fields: [createdById], references: [id])
  fields       FormField[]
  submissions  FormSubmission[]

  @@index([createdById])
  @@index([status])
}

model FormField {
  id        String        @id @default(uuid())
  formId    String
  label     String
  type      FormFieldType
  order     Int
  required  Boolean       @default(true)

  form      Form          @relation(fields: [formId], references: [id], onDelete: Cascade)
  values    FormFieldValue[]

  @@index([formId, order])
}

model FormSubmission {
  id          String   @id @default(uuid())
  formId      String
  userId      String
  submittedAt DateTime @default(now())

  form        Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id])
  values      FormFieldValue[]

  @@index([formId])
  @@index([userId])
}

model FormFieldValue {
  id             String         @id @default(uuid())
  submissionId   String
  fieldId        String
  value          String?        @db.Text

  submission     FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  field          FormField      @relation(fields: [fieldId], references: [id])

  @@index([submissionId])
  @@index([fieldId])
}

