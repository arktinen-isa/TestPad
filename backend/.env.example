NODE_ENV=production
PORT=3000

# MySQL — увага: символ @ у паролі замінити на %40 у DATABASE_URL
# Приклад: пароль g_89iKn2@K → g_89iKn2%40K у рядку підключення
DATABASE_URL="mysql://omfcpit_testpad:g_89iKn2%40K@omfcpit.mysql.tools:3306/omfcpit_testpad"

# JWT — генерувати командою:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-96-char-hex-secret
JWT_REFRESH_SECRET=your-other-96-char-hex-secret

JWT_EXPIRES_IN=15m

# Railway Redis Plugin підставляє автоматично через ${{Redis.REDIS_URL}}
REDIS_URL=redis://localhost:6379

FRONTEND_URL=https://your-app.up.railway.app
